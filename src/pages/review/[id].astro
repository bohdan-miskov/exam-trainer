---
import rawMarkdown from '../../data/questions.md?raw';
import { parseMarkdown } from '../../utils/parser';
import QuizApp from '../../components/QuizApp';
import { neon } from '@neondatabase/serverless';
import { drizzle } from 'drizzle-orm/neon-http';
import { wrongAnswers, bookmarks } from '../../db/schema';
import Layout from '../../layouts/Layout.astro';

const { id } = Astro.params;
const attemptId = id ? parseInt(id, 10) : undefined;

// 1. Серверний парсинг питань з Markdown
const allQuestions = parseMarkdown(rawMarkdown);

// 2. Отримуємо дані з БД
const sql = neon(import.meta.env.DATABASE_URL);
const db = drizzle(sql);

const wrongRows = await db.select({ questionId: wrongAnswers.questionId }).from(wrongAnswers);
const initialWrongIds = [...new Set(wrongRows.map(r => r.questionId))];

const bookmarkRows = await db.select({ questionId: bookmarks.questionId }).from(bookmarks);
const initialBookmarkedIds = [...new Set(bookmarkRows.map(r => r.questionId))];
---

<Layout title={`AWS Prep - Attempt Review #${id}`}>
  {attemptId !== undefined && !isNaN(attemptId) ? (
    <QuizApp 
      allQuestions={allQuestions} 
      initialWrongIds={initialWrongIds} 
      initialBookmarkedIds={initialBookmarkedIds}
      initialScreen="results"
      reviewAttemptId={attemptId}
      client:load 
    />
  ) : (
    <div style="padding: 40px; text-align: center; color: var(--text-color);">
      <h2>Invalid Attempt ID</h2>
      <a href="/" style="color: var(--primary-color);">Return to Menu</a>
    </div>
  )}
</Layout>
